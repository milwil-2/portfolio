---
const GITHUB = "https://github.com/milwil-2";
const LINKEDIN = "https://www.linkedin.com/in/milanwillett/";
---

<header>
  <h1>milan willett</h1>
  <p class="bio">
    uc berkeley — data science w/ emphasis in economics. building with
    ai, ml, and computer vision. off the keyboard you'll find me climbing,
    sailing, or making matcha.
  </p>
  <nav>
    <a href={GITHUB} target="_blank" rel="noopener noreferrer">github ↗</a>
    <span class="sep">·</span>
    <a href={LINKEDIN} target="_blank" rel="noopener noreferrer">linkedin ↗</a>
  </nav>
</header>

<style>
  header {
    margin-bottom: 0.375rem;
  }

  h1 {
    font-size: 1.1em;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
  }

  .bio {
    color: #999;
    font-size: 0.9em;
    max-width: 52ch;
    margin-bottom: 1rem;
    padding-left: 1.25rem;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85em;
  }

  nav a {
    color: var(--muted);
    transition: color 0.15s;
  }

  nav a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .sep {
    color: var(--border);
  }
</style>
