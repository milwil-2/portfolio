---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card" data-card={project.summary ? '' : undefined}>
  <div class="card-header">
    <span class="name">[ {project.name} ]</span>
    <div class="meta">
      <span class="year">{project.year}</span>
      {project.live && (
        <a href={project.live} target="_blank" rel="noopener noreferrer" class="badge">live ↗</a>
      )}
      <a href={project.github} target="_blank" rel="noopener noreferrer" class="badge">github ↗</a>
    </div>
  </div>
  <p class="desc">{project.description}</p>
  <p class="tags">
    {project.tags.join(' · ')}
    {project.wip && <span class="wip">~ in development</span>}
  </p>
  {project.summary && (
    <div class="summary">
      <div class="summary-inner">
        <p class="summary-label">current</p>
        <ul class="dash-list">
          {project.summary.current.map((item) => <li>{item}</li>)}
        </ul>
        <p class="summary-label">roadmap</p>
        <ul class="dash-list">
          {project.summary.future.map((item) => <li>{item}</li>)}
        </ul>
        <button class="collapse-btn" data-collapse>[ collapse ]</button>
      </div>
    </div>
  )}
</article>

<style>
  .card {
    padding: 1.25rem 1rem;
    margin: 0 -1rem;
    border-bottom: 1px solid var(--border);
    border-radius: 4px;
    transition: background 0.2s ease;
  }

  .card:hover {
    background: var(--surface);
  }

  .card:last-child {
    border-bottom: none;
  }

  .card-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }

  .name {
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .year {
    color: var(--muted);
    font-size: 0.85em;
  }

  .badge {
    color: var(--muted);
    font-size: 0.85em;
    transition: color 0.15s;
  }

  .badge:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .desc {
    color: var(--text);
    font-size: 0.9em;
    margin-bottom: 0.35rem;
  }

  .tags {
    color: var(--muted);
    font-size: 0.8em;
  }

  .wip {
    margin-left: 0.75rem;
    color: #b8860b;
    font-size: 0.8em;
  }

  .card[data-card] {
    cursor: pointer;
  }

  .summary {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .card.open .summary {
    max-height: 600px;
  }

  .summary-inner {
    padding-top: 1rem;
  }

  .summary-label {
    color: var(--accent);
    font-size: 0.75em;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.4rem;
  }

  .dash-list {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
  }

  .dash-list li {
    color: #999;
    font-size: 0.85em;
    line-height: 1.7;
    padding-left: 1.1rem;
    text-indent: -1.1rem;
  }

  .dash-list li::before {
    content: "- ";
    color: var(--muted);
  }

  .collapse-btn {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: var(--muted);
    font-size: 0.8em;
    cursor: pointer;
    transition: color 0.15s;
  }

  .collapse-btn:hover {
    color: var(--accent);
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('[data-card]');

  cards.forEach((card) => {
    card.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a') || target.closest('[data-collapse]')) return;

      const isOpen = card.classList.contains('open');
      cards.forEach((c) => c.classList.remove('open'));
      if (!isOpen) card.classList.add('open');
    });

    card.querySelector('[data-collapse]')?.addEventListener('click', () => {
      card.classList.remove('open');
    });
  });
</script>
